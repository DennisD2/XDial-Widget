CC = gcc

SRCS = Dial.c Converters.c
SRCS1 = dial.c

OBJS = Dial.o Converters.o
OBJS1 = dial.o

INCDIR = .
DEBUG = -O
CFLAGS = $(DEBUG) -I$(INCDIR) -I/usr/X11R6/include -Wall

LDOPTIONS = -L. -L/usr/X11R6/lib -static
LOCAL_LIBRARIES = -lDial
SYS_LIBS = -lXaw -lXt -lX11 -lm -lxcb -lXau -lXdmcp -lSM -lICE
LDLIBS = $(LOCAL_LIBRARIES) $(SYS_LIBS)

NormalLibraryTarget(Dial,$(OBJS))

NormalProgramTarget(dial,dial.o,libDial.a,,)

DependTarget()

tar:
        rm -f XDial.tar
        tar cvf XDial.tar $(SRCS) $(SRCS1) Imakefile *.h *.man *.ad
